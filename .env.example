# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000

# ─── External APIs ───────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/skillforge_ai?retryWrites=true&w=majority

# ─── JWT Configuration ───────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_ACCESS_SECRET=your_64_byte_hex_access_secret_here
ACCESS_TOKEN_EXPIRES=7d

# Optional — reserved for refresh-token support (not yet active)
JWT_REFRESH_SECRET=your_64_byte_hex_refresh_secret_here
REFRESH_TOKEN_EXPIRES=30d
